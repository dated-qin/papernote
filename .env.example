# ============================================
# 纸条 PaperNote — 环境变量模板
# 复制为 .env 并填写实际值
# ============================================

# ---- 前端 ----
VITE_API_BASE=http://localhost:8080
VITE_WS_URL=ws://localhost:8081/ws

# ---- 后端 ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=papernote
DB_PASSWORD=change_me
DB_NAME=papernote

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me

JWT_SECRET=change_me_in_production_min_32_chars
JWT_EXPIRE_HOURS=24

# OSS（七牛云 Kodo / AWS S3 兼容）
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=papernote
OSS_ENDPOINT=https://s3-cn-east-1.qiniucs.com

# 端口
PORT=8080
WS_PORT=8081
